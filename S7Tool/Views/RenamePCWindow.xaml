<Window x:Class="S7Tool.Views.RenamePCWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="{DynamicResource Str_Rename_Title}"
        Height="480"
        Width="740"
        MinHeight="420"
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7F8;" FontFamily="{StaticResource IconFontFamily}" FontSize="20" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Str_Rename_Header}" FontSize="20" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock Text="{DynamicResource Str_Rename_Subtitle}" Margin="0,5,0,0" FontSize="13" Style="{StaticResource SubtitleTextStyle}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="15">

            <StackPanel>

                <TextBlock Text="{DynamicResource Str_Rename_CurrentName}" Style="{StaticResource SubtitleTextStyle}"/>
                <TextBlock Text="{Binding CurrentName}" Margin="0,5,0,10" FontSize="16" FontWeight="SemiBold"/>

                <TextBlock Text="{DynamicResource Str_Rename_NewName}" Style="{StaticResource SubtitleTextStyle}"/>
                <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" MaxLength="15"/>

                <TextBlock Text="{DynamicResource Str_Rename_Constraints}" FontSize="11" Style="{StaticResource SubtitleTextStyle}"/>

            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding StatusText}" FontSize="12" Style="{StaticResource SubtitleTextStyle}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="{DynamicResource Str_Common_Cancel}" Width="100" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}"/>
            <Button Content="{DynamicResource Str_Rename_Button}" Width="120" Command="{Binding RenameCommand}"/>
        </StackPanel>

    </Grid>
</Window>
