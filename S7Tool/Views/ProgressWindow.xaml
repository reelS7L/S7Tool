<Window x:Class="S7Tool.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="Progression"
        Height="220"
        Width="500"
        MinWidth="380"
        MinHeight="200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Border Style="{StaticResource CardBorderStyle}">

            <StackPanel>

                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <ProgressBar Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue}"/>

                <TextBlock Text="{Binding StatusText}" Margin="0,10,0,0" Style="{StaticResource SubtitleTextStyle}"/>

                <TextBlock Text="{Binding LogText}"
                           Margin="0,8,0,0"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>
