<Window x:Class="S7Tool.Views.WindowsUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="Windows Update"
        Height="720"
        Width="1100"
        MinWidth="750"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource CardBg2Brush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter VerticalAlignment="Center"/>

                                <Border x:Name="Switch" Grid.Column="1" Width="40" Height="20" CornerRadius="10" Background="{StaticResource TextMutedBrush}">
                                    <Ellipse x:Name="Knob" Width="16" Height="16" Fill="White" Margin="2" HorizontalAlignment="Left"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Switch" Property="Background" Value="{StaticResource SuccessBrush}"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardBg2Brush}" CornerRadius="18" Padding="16">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource DashboardTileIconStyle}" Margin="0,0,12,0">
                    <TextBlock Text="&#xE895;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="Windows Update" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Gestion des mises à jour système" FontSize="12" Style="{StaticResource SubtitleTextStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBgBrush}" CornerRadius="16" Padding="12">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Mises à jour importantes" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="Tout sélectionner" Style="{StaticResource ToggleLikeButtonStyle}" Command="{Binding SelectAllImportantCommand}"/>
                    </Grid>

                    <ScrollViewer Height="400">
                        <ItemsControl ItemsSource="{Binding ImportantUpdates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,4,0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource CardBgBrush}" CornerRadius="16" Padding="12">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Facultatives / Pilotes" FontWeight="Bold"/>
                        <Button Grid.Column="1" Content="Tout sélectionner" Style="{StaticResource ToggleLikeButtonStyle}" Command="{Binding SelectAllOptionalCommand}"/>
                    </Grid>

                    <ScrollViewer Height="400">
                        <ItemsControl ItemsSource="{Binding OptionalUpdates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Title}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,4,0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </Grid>

        <Border Grid.Row="3" Background="{StaticResource CardBg2Brush}" CornerRadius="16" Padding="12" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToggleButton Content="Autres produits Microsoft"
                              Width="220" Height="32"
                              VerticalAlignment="Center"
                              Style="{StaticResource SwitchToggleButtonStyle}"
                              IsChecked="{Binding IsMicrosoftUpdateEnabled, Mode=OneWay}"
                              Command="{Binding ToggleMicrosoftUpdateCommand}"/>

                <Button Grid.Column="1" Content="Rechercher" Margin="10,0" Style="{StaticResource ToggleLikeButtonStyle}" Command="{Binding SearchUpdatesCommand}"/>
                <Button Grid.Column="2" Content="Installer" Style="{StaticResource SuccessButtonStyle}" Command="{Binding InstallUpdatesCommand}"/>

            </Grid>
        </Border>

    </Grid>
</Window>
