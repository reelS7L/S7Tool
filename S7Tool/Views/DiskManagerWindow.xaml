<Window x:Class="S7Tool.Views.DiskManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="Gestionnaire de disques"
        Width="620"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Border Style="{StaticResource DashboardTileIconStyle}" Width="48" Height="48" Margin="0,0,14,0">
                <TextBlock Text="&#xEDA2;" FontFamily="{StaticResource IconFontFamily}" FontSize="20" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Gestionnaire de disques" Style="{StaticResource PageTitleTextStyle}"/>
                <TextBlock Text="Toute la gestion de disques se fait hors ligne, dans un environnement dédié" Style="{StaticResource SubtitleTextStyle}" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="18">
            <StackPanel>
                <TextBlock Text="Environnement hors ligne (WinPE)" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Le clonage, le redimensionnement, le déplacement, la création/suppression de partitions et toutes les autres opérations sensibles se font exclusivement dans le gestionnaire de disques hors ligne — jamais pendant que Windows tourne. L'image est embarquée avec l'application (ou téléchargée automatiquement si absente) : aucune installation requise sur ce poste."
                           Style="{StaticResource SubtitleTextStyle}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="0,0,0,14"/>

                <Button Content="Préparer l'environnement hors ligne" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" Command="{Binding PrepareOfflineEnvironmentCommand}"
                        Visibility="{Binding IsOfflineEnvironmentReady, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <Button Content="Mettre à jour l'environnement hors ligne" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" Command="{Binding PrepareOfflineEnvironmentCommand}"
                        Visibility="{Binding IsOfflineEnvironmentUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="Lancer le gestionnaire de disques hors ligne" Command="{Binding LaunchOfflineDiskManagerCommand}"
                        Visibility="{Binding IsOfflineEnvironmentReady, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="8" Height="160" Margin="0,14,0,0">
                    <ListBox ItemsSource="{Binding OfflineEnvironmentLogs}" Background="Transparent" FontSize="11"/>
                </Border>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding StatusText}" Style="{StaticResource SubtitleTextStyle}"/>

    </Grid>
</Window>
