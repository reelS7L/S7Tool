<Window x:Class="S7Tool.Views.DiskManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="{DynamicResource Str_DiskMgr_Title}"
        Width="620"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Border Style="{StaticResource DashboardTileIconStyle}" Width="48" Height="48" Margin="0,0,14,0">
                <TextBlock Text="&#xEDA2;" FontFamily="{StaticResource IconFontFamily}" FontSize="20" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Str_DiskMgr_Title}" Style="{StaticResource PageTitleTextStyle}"/>
                <TextBlock Text="{DynamicResource Str_DiskMgr_Subtitle}" Style="{StaticResource SubtitleTextStyle}" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="18">
            <StackPanel>
                <TextBlock Text="{DynamicResource Str_DiskMgr_OfflineEnvTitle}" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="{DynamicResource Str_DiskMgr_OfflineEnvDescription}"
                           Style="{StaticResource SubtitleTextStyle}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14"/>

                <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="0,0,0,14"/>

                <Button Content="{DynamicResource Str_DiskMgr_PrepareOffline}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" Command="{Binding PrepareOfflineEnvironmentCommand}"
                        Visibility="{Binding IsOfflineEnvironmentReady, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <Button Content="{DynamicResource Str_DiskMgr_UpdateOffline}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" Command="{Binding PrepareOfflineEnvironmentCommand}"
                        Visibility="{Binding IsOfflineEnvironmentUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="{DynamicResource Str_DiskMgr_LaunchOffline}" Command="{Binding LaunchOfflineDiskManagerCommand}"
                        Visibility="{Binding IsOfflineEnvironmentReady, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="8" Height="160" Margin="0,14,0,0">
                    <ListBox ItemsSource="{Binding OfflineEnvironmentLogs}" Background="Transparent" FontSize="11"/>
                </Border>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding StatusText}" Style="{StaticResource SubtitleTextStyle}"/>

    </Grid>
</Window>
