<Window x:Class="S7Tool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        Title="s7Tool"
        Height="742"
        Width="1432"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="56"
                        Height="56"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12">
                    <Image Source="/Resources/logo/logoTool.ico"
                           Stretch="Uniform"
                           Margin="8"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="s7Tool" Style="{StaticResource PageTitleTextStyle}"/>
                    <TextBlock Text="Menu système + gestion avancée" Style="{StaticResource SubtitleTextStyle}"/>
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" MinWidth="420"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BorderSoftBrush}"
                          Cursor="SizeWE"
                          ResizeBehavior="PreviousAndNext"/>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="{StaticResource SurfaceBrush}" Padding="18">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Actions" FontSize="16" FontWeight="Bold" Margin="0,0,0,14"/>

                        <WrapPanel>

                            <Button Command="{Binding OpenAiChatCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE8F2;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="IA Helper" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Assistant conversationnel" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding UninstallAppsCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE74D;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Désinstaller des applications" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Sélection multiple, mode silencieux" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding DisableFastStartupCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE713;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Désactiver démarrage rapide" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Fast Startup Windows" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding RenamePCCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE70F;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Renommer le PC" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Nom de la machine" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenWindowsUpdateCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE72C;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Windows Update Manager" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Recherche et installation" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenNetworkScannerCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE968;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Scanner réseau" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Découverte des appareils du réseau" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenPortScannerCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE99A;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Scanner de ports" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Ports TCP ouverts sur un hôte" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenDiskManagerCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xEDA2;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Gestionnaire de disques" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Redimensionnement et clonage" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenDiskHealthCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE9D9;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Santé des disques" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="SMART/NVMe bas niveau" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenDiskSpaceAnalyzerCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}">
                                        <TextBlock Text="&#xE9D2;" Style="{StaticResource DashboardTileGlyphStyle}"/>
                                    </Border>
                                    <TextBlock Text="Analyseur d'espace disque" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Scan et navigation par taille" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding QuitCommand}" Style="{StaticResource DashboardTileStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource DashboardTileIconStyle}" Background="{StaticResource DangerBrush}">
                                        <TextBlock Text="&#xE711;" Style="{StaticResource DashboardTileGlyphStyle}" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Quitter" Style="{StaticResource DashboardTileTitleStyle}"/>
                                    <TextBlock Text="Fermer l'application" Style="{StaticResource DashboardTileSubtitleStyle}"/>
                                </StackPanel>
                            </Button>

                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" CornerRadius="22">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Task Manager" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="CPU / RAM / DISK monitoring" Style="{StaticResource SubtitleTextStyle}" FontSize="11"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Height="34" Margin="0,0,8,0"
                                Padding="12,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshProcessesCommand}"
                                ToolTip="Actualiser la liste des processus">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFontFamily}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Actualiser" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Width="90" Height="34"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding TogglePauseCommand}"
                                Content="{Binding PauseButtonLabel}"/>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sort by:" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,8,0" VerticalAlignment="Center"/>

                            <ComboBox Width="120" SelectedValuePath="Content" SelectedValue="{Binding SortMode, Mode=TwoWay}">
                                <ComboBoxItem Content="CPU"/>
                                <ComboBoxItem Content="RAM"/>
                                <ComboBoxItem Content="DISK"/>
                                <ComboBoxItem Content="NAME"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="14" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Live" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                            <TextBlock Text="   |   " Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="Auto refresh ON (1s)" Style="{StaticResource SubtitleTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="6">

                        <DataGrid ItemsSource="{Binding Processes}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="2*"/>
                                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="*"/>
                                <DataGridTextColumn Header="CPU %" Binding="{Binding Cpu}" Width="*"/>
                                <DataGridTextColumn Header="RAM MB" Binding="{Binding Memory}" Width="*"/>
                                <DataGridTextColumn Header="DISK" Binding="{Binding Disk}" Width="*"/>

                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="26" Height="26"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Padding="0"
                                                    FontWeight="Bold"
                                                    FontSize="12"
                                                    ToolTip="Arrêter ce processus"
                                                    Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Id}"
                                                    Content="X"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                        </DataGrid>
                    </Border>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Window>
