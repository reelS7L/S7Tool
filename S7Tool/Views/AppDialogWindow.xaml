<Window x:Class="S7Tool.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource AppWindowStyle}"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        MaxHeight="640"
        MinWidth="380"
        MinHeight="180"
        Width="500">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="IconBadge" Width="40" Height="40" CornerRadius="20">
                <TextBlock x:Name="IconGlyph"
                           FontFamily="{StaticResource IconFontFamily}"
                           FontSize="18"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="TitleText"
                       Grid.Column="1"
                       FontSize="17"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,22">
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       FontSize="14"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="Annuler"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>

            <Button x:Name="ConfirmButton"
                    Content="OK"
                    Width="110"
                    Click="Confirm_Click"/>
        </StackPanel>

    </Grid>
</Window>
