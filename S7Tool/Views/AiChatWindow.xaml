<Window x:Class="S7Tool.Views.AiChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:S7Tool.Helpers"
        Style="{StaticResource AppWindowStyle}"
        Title="s7Tool AI"
        Height="700"
        Width="1100"
        MinWidth="700"
        MinHeight="450"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <helpers:MarkdownToFlowDocumentConverter x:Key="MarkdownConverter"/>
    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource CardBgBrush}" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Mon Pote GPT" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource SubtitleTextStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                    <Button Content="Régénérer"
                            Margin="0,0,8,0"
                            Style="{StaticResource ToggleLikeButtonStyle}"
                            Command="{Binding RegenerateLastCommand}"/>
                    <Button Content="Nouvelle conversation"
                            Margin="0,0,8,0"
                            Style="{StaticResource ToggleLikeButtonStyle}"
                            Command="{Binding ClearConversationCommand}"/>
                    <Button Width="32" Height="32"
                            Padding="0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="Paramètres de l'IA (clé API)"
                            Command="{Binding OpenSettingsCommand}">
                        <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFontFamily}" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="10">

            <ItemsControl ItemsSource="{Binding Messages}" Margin="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Padding="12" Margin="0,0,0,10" MaxWidth="800">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource CardBg2Brush}"/>
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Border Width="20" Height="20" CornerRadius="10" Margin="0,0,8,0" Background="{StaticResource SurfaceBrush}">
                                        <TextBlock FontFamily="{StaticResource IconFontFamily}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE99A;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Text" Value="&#xE77B;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding Role}" FontWeight="Bold" VerticalAlignment="Center"/>

                                    <Button Margin="10,0,0,0"
                                            Padding="6,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding CopyCommand}"
                                            Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFontFamily}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Copier" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Visibility="{Binding IsTyping, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="en train d'écrire..." Style="{StaticResource SubtitleTextStyle}" FontStyle="Italic"/>
                                </StackPanel>

                                <FlowDocumentScrollViewer Document="{Binding Text, Converter={StaticResource MarkdownConverter}}"
                                                           Visibility="{Binding IsTyping, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                           IsSelectionEnabled="True"
                                                           Background="Transparent"
                                                           VerticalScrollBarVisibility="Disabled"
                                                           HorizontalScrollBarVisibility="Disabled"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource CardBgBrush}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="15"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="55"
                         PreviewKeyDown="InputBox_PreviewKeyDown"/>

                <Button Grid.Column="1"
                        Content="Envoyer"
                        Command="{Binding SendCommand}"
                        Margin="10,0,0,0"
                        Height="55"
                        Visibility="{Binding IsSending, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                <Button Grid.Column="1"
                        Content="Arrêter"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding StopCommand}"
                        Margin="10,0,0,0"
                        Height="55"
                        Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

    </Grid>
</Window>
